# LLM provider: deepseek (default), ollama, or openai
LLM_PROVIDER=deepseek

# Common timeout for provider HTTP calls
LLM_TIMEOUT_SEC=20

# Debug LLM responses (set to 1 to enable logging)
LLM_DEBUG=0

# DeepSeek config
DEEPSEEK_API_KEY=yourkey
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_TIMEOUT_CONNECT_SEC=5
DEEPSEEK_TIMEOUT_READ_SEC=45
DEEPSEEK_MAX_TOKENS=220
DEEPSEEK_RETRIES=2

# OpenAI-compatible config (works with OpenAI, Together, Groq, etc.)
# Set LLM_PROVIDER=openai to use this provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_CONNECT_SEC=5
OPENAI_TIMEOUT_READ_SEC=20
OPENAI_MAX_TOKENS=220

# Ollama config (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Web search providers for /web-search endpoint
# Available: brave, searxng, serpapi
WEB_SEARCH_PROVIDERS=searxng
WEB_SEARCH_TIMEOUT_SEC=8

# Brave Search API
#BRAVE_SEARCH_API_KEY=
#BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1/web/search

# SerpAPI
#SERPAPI_API_KEY=
#SERPAPI_BASE_URL=https://serpapi.com/search.json

# SearXNG (self-hosted/public instance URL without trailing slash)
SEARXNG_BASE_URL=https://your.search.resource

# Web scraper settings (for deep analysis)
SCRAPER_TIMEOUT_CONNECT_SEC=5
SCRAPER_TIMEOUT_READ_SEC=15
SCRAPER_MAX_CHARS=8000

# Deep analysis / LLM synthesis settings
SYNTHESIS_MAX_TOKENS=1500
